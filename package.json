{
  "name": "opsdeck-website",
  "type": "module",
  "version": "1.0.0",
  "scripts": {
    "dev": "astro dev",
    "dev:docs": "mkdocs serve -f mkdocs.yml",
    "build": "astro build && mkdocs build -f mkdocs.yml",
    "build:site": "astro build",
    "build:docs": "mkdocs build -f mkdocs.yml",
    "build:pdf": "bash scripts/build-pdf.sh",
    "preview": "astro preview"
  },
  "dependencies": {
    "@astrojs/tailwind": "^5.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "astro": "^4.16.0",
    "tailwindcss": "^3.4.0"
  }
}
