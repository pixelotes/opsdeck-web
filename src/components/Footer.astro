---
const base = import.meta.env.BASE_URL;

const productLinks = [
  { label: 'Features', href: '#features' },
  { label: 'Enterprise', href: '#enterprise' },
  { label: 'Pricing', href: '#pricing' },
  { label: 'Changelog', href: 'https://github.com/pixelotes/opsdeck/releases' },
];

const resourceLinks = [
  { label: 'Documentation', href: `${base}/docs/` },
  { label: 'GitHub', href: 'https://github.com/pixelotes/opsdeck' },
  { label: 'Docker Hub', href: 'https://hub.docker.com/r/pixelotes/opsdeck' },
  { label: 'API Reference', href: `${base}/api-reference/` },
];

const communityLinks = [
  { label: 'GitHub Issues', href: 'https://github.com/pixelotes/opsdeck/issues' },
  { label: 'Discussions', href: 'https://github.com/pixelotes/opsdeck/discussions' },
  { label: 'Contributing', href: 'https://github.com/pixelotes/opsdeck/blob/main/CONTRIBUTING.md' },
];
---

<footer class="relative border-t border-white/5 bg-od-bg">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-indigo-500/20 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid sm:grid-cols-2 lg:grid-cols-5 gap-10 lg:gap-8">
      <!-- Brand column (2 cols wide on lg) -->
      <div class="sm:col-span-2">
        <!-- Logo -->
        <a href={base} class="flex items-center gap-2 group w-fit mb-4">
          <div class="flex items-center justify-center w-8 h-8 rounded-lg bg-gradient-to-br from-indigo-500 to-violet-600">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="3" width="7" height="7" rx="1"/>
              <rect x="14" y="3" width="7" height="7" rx="1"/>
              <rect x="3" y="14" width="7" height="7" rx="1"/>
              <rect x="14" y="14" width="7" height="7" rx="1"/>
            </svg>
          </div>
          <span class="text-lg font-bold text-white group-hover:text-indigo-300 transition-colors">OpsDeck</span>
        </a>

        <p class="text-sm text-slate-400 leading-relaxed mb-6 max-w-xs">
          Open source IT governance for teams that care about security.
        </p>

        <!-- GitHub link -->
        <a
          href="https://github.com/pixelotes/opsdeck"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-4 py-2 bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-lg text-sm text-slate-400 hover:text-white transition-all duration-200"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
          pixelotes/opsdeck
        </a>

        <!-- License badge -->
        <div class="mt-4 flex items-center gap-2">
          <span class="inline-flex items-center px-2 py-1 rounded text-xs font-medium bg-indigo-500/10 text-indigo-300 border border-indigo-500/20">
            Apache 2.0
          </span>
          <span class="text-xs text-slate-600">Open Source License</span>
        </div>
      </div>

      <!-- Product links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Product</h3>
        <ul class="space-y-3">
          {productLinks.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-slate-500 hover:text-slate-300 transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Resources</h3>
        <ul class="space-y-3">
          {resourceLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target={link.href.startsWith('http') ? '_blank' : undefined}
                rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
                class="text-sm text-slate-500 hover:text-slate-300 transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Community links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest text-slate-400 mb-4">Community</h3>
        <ul class="space-y-3">
          {communityLinks.map((link) => (
            <li>
              <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-sm text-slate-500 hover:text-slate-300 transition-colors duration-200"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-16 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-sm text-slate-600">
        &copy; 2025 OpsDeck. Open Source under
        <a
          href="https://github.com/pixelotes/opsdeck/blob/main/LICENSE"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-500 hover:text-slate-300 transition-colors"
        >
          Apache 2.0 License
        </a>.
      </p>

      <div class="flex items-center gap-4">
        <a
          href="https://github.com/pixelotes/opsdeck"
          target="_blank"
          rel="noopener noreferrer"
          class="text-slate-600 hover:text-slate-400 transition-colors"
          aria-label="GitHub"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</footer>
