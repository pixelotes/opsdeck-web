---
const check = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
const cross = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>`;

const sections = [
  {
    title: 'Core Platform',
    rows: [
      { feature: 'Asset & inventory management', oss: 'check', ent: 'check' },
      { feature: 'Compliance frameworks (SOC 2, ISO 27001)', oss: 'check', ent: 'check' },
      { feature: 'Risk register & security incidents', oss: 'check', ent: 'check' },
      { feature: 'User Access Review', oss: 'check', ent: 'check' },
      { feature: 'Vendor & procurement management', oss: 'check', ent: 'check' },
      { feature: 'Service mapping & dependency graphs', oss: 'check', ent: 'check' },
      { feature: 'Credentials vault (encrypted)', oss: 'check', ent: 'check' },
      { feature: 'Policy & training management', oss: 'check', ent: 'check' },
      { feature: 'HR onboarding & offboarding', oss: 'check', ent: 'check' },
    ],
  },
  {
    title: 'Access & Security',
    rows: [
      { feature: 'SAML SSO', oss: 'check', ent: 'check' },
      { feature: 'Multi-factor authentication (TOTP)', oss: 'check', ent: 'check' },
      { feature: 'Granular RBAC', oss: 'check', ent: 'check' },
      { feature: 'Full audit log', oss: 'check', ent: 'check' },
      { feature: 'REST API (OpenAPI / Swagger)', oss: 'check', ent: 'check' },
    ],
  },
  {
    title: 'Scale',
    rows: [
      { feature: 'Unlimited users', oss: 'check', ent: 'check' },
      { feature: 'Unlimited assets & records', oss: 'check', ent: 'check' },
      { feature: 'Self-hosted (your infrastructure)', oss: 'check', ent: 'check' },
    ],
  },
  {
    title: 'Enterprise Add-ons',
    rows: [
      { feature: 'API Connectors (GitHub, Google, AWS, Atlassian, M365, JumpCloud)', oss: 'cross', ent: 'check' },
      { feature: 'AI Agent & automation', oss: 'cross', ent: 'check' },
      { feature: 'Automated UAR sync from connectors', oss: 'cross', ent: 'check' },
      { feature: 'Scheduled connector reports', oss: 'cross', ent: 'check' },
    ],
  },
  {
    title: 'Support',
    rows: [
      { feature: 'Support channel', oss: 'text:GitHub Issues', ent: 'text:Priority SLA' },
      { feature: 'Response time', oss: 'text:Best effort', ent: 'text:< 4 hours' },
      { feature: 'Dedicated Customer Success Manager', oss: 'cross', ent: 'check' },
    ],
  },
];
---

<section class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_60%_40%_at_50%_0%,rgba(99,102,241,0.06),transparent)]"></div>

  <div class="relative max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-12">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-green-500/10 border border-green-500/30 text-green-300 text-sm font-medium mb-6">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
        No Hidden Gates
      </div>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight mb-4">
        Everything in the open.
      </h2>
      <p class="text-xl text-slate-400 max-w-2xl mx-auto">
        The OSS version has <span class="text-white font-semibold">everything</span> — SAML SSO, unlimited users, full API, RBAC. Nothing is gated except connectors, AI, and premium support.
      </p>
    </div>

    <!-- Comparison table -->
    <div class="bg-od-surface rounded-2xl border border-white/5 overflow-hidden shadow-2xl shadow-black/30">
      <!-- Header row -->
      <div class="grid grid-cols-3 bg-od-bg/60 border-b border-white/10">
        <div class="px-6 py-4">
          <span class="text-sm font-medium text-slate-400">Feature</span>
        </div>
        <div class="px-6 py-4 text-center border-l border-white/5">
          <span class="text-sm font-semibold text-white">Community</span>
          <div class="text-xs text-green-400 mt-0.5">Free forever</div>
        </div>
        <div class="px-6 py-4 text-center border-l border-white/5 bg-indigo-500/5">
          <span class="text-sm font-semibold text-indigo-300">Enterprise</span>
          <div class="text-xs text-indigo-400 mt-0.5">Add-on plugin</div>
        </div>
      </div>

      <!-- Sections -->
      {sections.map((section, si) => (
        <>
          <!-- Section header -->
          <div class={`px-6 py-3 bg-od-bg/40 ${si > 0 ? 'border-t border-white/10' : ''}`}>
            <span class="text-xs font-semibold uppercase tracking-widest text-slate-500">{section.title}</span>
          </div>

          <!-- Rows -->
          {section.rows.map((row, ri) => {
            const renderCell = (val: string) => {
              if (val === 'check') return check;
              if (val === 'cross') return cross;
              if (val.startsWith('text:')) return `<span class="text-sm text-slate-300">${val.slice(5)}</span>`;
              return val;
            };

            return (
              <div class={`grid grid-cols-3 ${ri < section.rows.length - 1 ? 'border-b border-white/5' : ''} hover:bg-white/[0.02] transition-colors`}>
                <div class="px-6 py-3.5">
                  <span class="text-sm text-slate-400">{row.feature}</span>
                </div>
                <div class="px-6 py-3.5 flex items-center justify-center border-l border-white/5" set:html={renderCell(row.oss)}></div>
                <div class="px-6 py-3.5 flex items-center justify-center border-l border-white/5 bg-indigo-500/[0.03]" set:html={renderCell(row.ent)}></div>
              </div>
            );
          })}
        </>
      ))}
    </div>

    <!-- Bottom note -->
    <p class="text-center text-sm text-slate-500 mt-6">
      The Enterprise Plugin installs <span class="text-slate-400">alongside</span> your open-source instance. Uninstall anytime — your data stays yours.
    </p>
  </div>
</section>
