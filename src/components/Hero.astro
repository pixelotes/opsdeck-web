---
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden pt-16">
  <!-- Grid background -->
  <div class="absolute inset-0 bg-grid-pattern opacity-100"></div>

  <!-- Radial gradient overlay -->
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_80%_50%_at_50%_-20%,rgba(99,102,241,0.15),transparent)]"></div>
  <div class="absolute top-0 left-1/4 w-96 h-96 bg-indigo-500/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute top-20 right-1/4 w-64 h-64 bg-violet-500/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Left: Text content -->
      <div class="text-center lg:text-left">
        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-indigo-500/10 border border-indigo-500/30 text-indigo-300 text-sm font-medium mb-8">
          <span class="flex w-2 h-2 rounded-full bg-indigo-400 animate-pulse"></span>
          100% Open Source · Self-Hosted
        </div>

        <!-- H1 -->
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold tracking-tight leading-tight mb-6">
          The IT Operations Platform
          <span class="block mt-1 bg-gradient-to-r from-indigo-400 to-violet-400 bg-clip-text text-transparent">
            Your Team Will Actually Use
          </span>
        </h1>

        <!-- Subtitle -->
        <p class="text-lg sm:text-xl text-slate-400 leading-relaxed mb-10 max-w-xl mx-auto lg:mx-0">
          Asset management, compliance tracking, risk management, UAR, and more — unified in a single open-source platform.
          <span class="text-slate-300 font-medium"> No per-seat pricing. No feature gates.</span>
        </p>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href="https://github.com/pixelotes/opsdeck"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-white bg-gradient-to-r from-indigo-600 to-violet-600 hover:from-indigo-500 hover:to-violet-500 rounded-xl transition-all duration-200 shadow-xl shadow-indigo-500/30 hover:shadow-indigo-500/50 hover:-translate-y-0.5"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/>
              <polyline points="13 2 13 9 20 9"/>
            </svg>
            Deploy in minutes
          </a>
          <a
            href="https://github.com/pixelotes/opsdeck"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-6 py-3 text-base font-semibold text-slate-300 hover:text-white bg-white/5 hover:bg-white/10 border border-white/10 hover:border-white/20 rounded-xl transition-all duration-200 hover:-translate-y-0.5"
          >
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
            </svg>
            Star on GitHub
          </a>
        </div>

        <!-- Social proof -->
        <div class="mt-10 pt-8 border-t border-white/5 flex flex-col sm:flex-row items-center lg:items-start gap-6 text-sm text-slate-500">
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>Apache 2.0 License</span>
          </div>
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>Docker & Kubernetes ready</span>
          </div>
          <div class="flex items-center gap-2">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
            <span>40+ modules included</span>
          </div>
        </div>
      </div>

      <!-- Right: Dashboard mockup -->
      <div class="relative hidden lg:block">
        <!-- Glow behind the mockup -->
        <div class="absolute inset-0 bg-gradient-to-r from-indigo-500/20 to-violet-500/20 rounded-2xl blur-2xl transform scale-110"></div>

        <!-- Browser chrome -->
        <div class="relative rounded-2xl border border-white/10 bg-od-surface shadow-2xl shadow-black/50 overflow-hidden">
          <!-- Browser top bar -->
          <div class="flex items-center gap-2 px-4 py-3 bg-od-surface-2 border-b border-white/5">
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-green-500/80"></div>
            </div>
            <div class="flex-1 mx-4">
              <div class="flex items-center gap-2 bg-od-bg/60 rounded-md px-3 py-1 text-xs text-slate-500 border border-white/5">
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                opsdeck.internal
              </div>
            </div>
          </div>

          <!-- App layout -->
          <div class="flex h-[420px]">
            <!-- Sidebar -->
            <div class="w-48 bg-od-bg border-r border-white/5 flex flex-col py-4">
              <div class="px-3 mb-4">
                <div class="flex items-center gap-2 px-2 py-1.5">
                  <div class="w-6 h-6 rounded bg-gradient-to-br from-indigo-500 to-violet-600 flex items-center justify-center">
                    <div class="w-2.5 h-2.5 grid grid-cols-2 gap-0.5">
                      <div class="bg-white rounded-sm w-1 h-1"></div>
                      <div class="bg-white rounded-sm w-1 h-1"></div>
                      <div class="bg-white rounded-sm w-1 h-1"></div>
                      <div class="bg-white rounded-sm w-1 h-1"></div>
                    </div>
                  </div>
                  <span class="text-xs font-bold text-white">OpsDeck</span>
                </div>
              </div>

              <nav class="flex-1 px-2 space-y-0.5 text-xs">
                <div class="flex items-center gap-2 px-2 py-1.5 rounded-md bg-indigo-500/20 text-indigo-300">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="3" width="7" height="7"/>
                    <rect x="14" y="3" width="7" height="7"/>
                    <rect x="3" y="14" width="7" height="7"/>
                    <rect x="14" y="14" width="7" height="7"/>
                  </svg>
                  Dashboard
                </div>
                <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-slate-500 hover:text-slate-300">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="2" y="3" width="20" height="14" rx="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                  </svg>
                  Assets
                </div>
                <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-slate-500">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                  </svg>
                  Compliance
                </div>
                <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-slate-500">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                  </svg>
                  Risk
                </div>
                <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-slate-500">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                    <circle cx="9" cy="7" r="4"/>
                    <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
                    <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                  </svg>
                  UAR
                </div>
                <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-slate-500">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
                    <line x1="3" y1="6" x2="21" y2="6"/>
                  </svg>
                  Vendors
                </div>
                <div class="flex items-center gap-2 px-2 py-1.5 rounded-md text-slate-500">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"/>
                    <line x1="12" y1="8" x2="12" y2="12"/>
                    <line x1="12" y1="16" x2="12.01" y2="16"/>
                  </svg>
                  Incidents
                </div>
              </nav>

              <div class="px-3 mt-auto">
                <div class="flex items-center gap-2 px-2 py-2 rounded-md bg-white/5 border border-white/5">
                  <div class="w-5 h-5 rounded-full bg-gradient-to-br from-indigo-400 to-violet-400 flex items-center justify-center text-white text-xs font-bold">J</div>
                  <div>
                    <div class="text-xs text-white leading-tight">Jane D.</div>
                    <div class="text-xs text-slate-500 leading-tight">Admin</div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Main content area -->
            <div class="flex-1 bg-od-bg overflow-hidden">
              <!-- Top bar -->
              <div class="flex items-center justify-between px-4 py-3 border-b border-white/5">
                <div>
                  <h2 class="text-xs font-semibold text-white">Dashboard</h2>
                  <p class="text-xs text-slate-500">Welcome back, Jane</p>
                </div>
                <div class="flex items-center gap-2">
                  <div class="w-5 h-5 rounded-full bg-od-surface-2 flex items-center justify-center">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="#94a3b8" stroke-width="2">
                      <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                      <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                    </svg>
                  </div>
                </div>
              </div>

              <!-- Stats grid -->
              <div class="p-3 grid grid-cols-2 gap-2">
                <!-- Stat cards -->
                <div class="bg-od-surface rounded-lg p-2.5 border border-white/5">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs text-slate-500">Total Assets</span>
                    <div class="w-4 h-4 rounded bg-indigo-500/20 flex items-center justify-center">
                      <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#6366f1" stroke-width="2.5">
                        <rect x="2" y="3" width="20" height="14" rx="2"/>
                      </svg>
                    </div>
                  </div>
                  <div class="text-lg font-bold text-white">247</div>
                  <div class="text-xs text-green-400 mt-0.5">+12 this month</div>
                </div>

                <div class="bg-od-surface rounded-lg p-2.5 border border-white/5">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs text-slate-500">Open Risks</span>
                    <div class="w-4 h-4 rounded bg-amber-500/20 flex items-center justify-center">
                      <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#f59e0b" stroke-width="2.5">
                        <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="text-lg font-bold text-white">18</div>
                  <div class="text-xs text-amber-400 mt-0.5">3 high severity</div>
                </div>

                <div class="bg-od-surface rounded-lg p-2.5 border border-white/5">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs text-slate-500">Incidents</span>
                    <div class="w-4 h-4 rounded bg-red-500/20 flex items-center justify-center">
                      <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#ef4444" stroke-width="2.5">
                        <circle cx="12" cy="12" r="10"/>
                        <line x1="12" y1="8" x2="12" y2="12"/>
                        <line x1="12" y1="16" x2="12.01" y2="16"/>
                      </svg>
                    </div>
                  </div>
                  <div class="text-lg font-bold text-white">3</div>
                  <div class="text-xs text-red-400 mt-0.5">1 active</div>
                </div>

                <div class="bg-od-surface rounded-lg p-2.5 border border-white/5">
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-xs text-slate-500">Controls</span>
                    <div class="w-4 h-4 rounded bg-green-500/20 flex items-center justify-center">
                      <svg width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2.5">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                      </svg>
                    </div>
                  </div>
                  <div class="text-lg font-bold text-white">42</div>
                  <div class="text-xs text-green-400 mt-0.5">89% compliant</div>
                </div>
              </div>

              <!-- Recent activity -->
              <div class="px-3 pb-3">
                <div class="bg-od-surface rounded-lg border border-white/5 overflow-hidden">
                  <div class="flex items-center justify-between px-3 py-2 border-b border-white/5">
                    <span class="text-xs font-semibold text-slate-300">Recent Activity</span>
                    <span class="text-xs text-slate-500">View all</span>
                  </div>
                  <div class="divide-y divide-white/5">
                    <div class="flex items-center gap-2 px-3 py-2">
                      <div class="w-1.5 h-1.5 rounded-full bg-indigo-400 flex-shrink-0"></div>
                      <span class="text-xs text-slate-400 flex-1">Asset MBP-112 assigned to Alex R.</span>
                      <span class="text-xs text-slate-600">2m ago</span>
                    </div>
                    <div class="flex items-center gap-2 px-3 py-2">
                      <div class="w-1.5 h-1.5 rounded-full bg-green-400 flex-shrink-0"></div>
                      <span class="text-xs text-slate-400 flex-1">SOC 2 Control CC6.1 marked compliant</span>
                      <span class="text-xs text-slate-600">18m ago</span>
                    </div>
                    <div class="flex items-center gap-2 px-3 py-2">
                      <div class="w-1.5 h-1.5 rounded-full bg-amber-400 flex-shrink-0"></div>
                      <span class="text-xs text-slate-400 flex-1">Risk R-042 severity updated to High</span>
                      <span class="text-xs text-slate-600">1h ago</span>
                    </div>
                    <div class="flex items-center gap-2 px-3 py-2">
                      <div class="w-1.5 h-1.5 rounded-full bg-violet-400 flex-shrink-0"></div>
                      <span class="text-xs text-slate-400 flex-1">UAR cycle Q1-2025 initiated</span>
                      <span class="text-xs text-slate-600">3h ago</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
